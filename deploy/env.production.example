# Copier vers deploy/.env sur le VPS et remplacer YOUR_VPS_IP + secrets.
# cp env.production.example .env

VPS_IP=YOUR_VPS_IP

POSTGRES_USER=ophthoccare
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ophthoccare_db

# --- Backend ---
NODE_ENV=production
PORT=3001
API_URL=http://YOUR_VPS_IP:3001
FRONTEND_URL=http://YOUR_VPS_IP:3000
CORS_ORIGIN=http://YOUR_VPS_IP:3000

JWT_SECRET=GENERATE_WITH_openssl_rand_base64_32
JWT_ACCESS_EXPIRY=15m

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

LOG_LEVEL=info

# Optionnel (recherche annuaire avancée)
ELASTICSEARCH_URL=

# --- Frontend (NEXT_PUBLIC_* = build-time ; rebuild web si l’IP change) ---
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:3001
NEXT_PUBLIC_ENABLE_VIDEO_CONSULTATION=true
NEXT_PUBLIC_ENABLE_AI_FEATURES=false

NEXTAUTH_URL=http://YOUR_VPS_IP:3000
NEXTAUTH_SECRET=GENERATE_DIFFERENT_SECRET_MIN_32_CHARS
AUTH_TRUST_HOST=true

# Note : PORT=3001 ci-dessus est pour l’API. Le frontend force PORT=3000 dans docker-compose.prod.yml.
