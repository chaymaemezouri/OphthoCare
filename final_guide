```
```bash
#!/bin/bash
DATE=$(date +%Y%m%d_%H%M%S)
pg_dump $DATABASE_URL | gzip > /tmp/backup_$DATE.sql.gz
aws s3 cp /tmp/backup_$DATE.sql.gz s3://ophthocare-backups/postgresql/
rm /tmp/backup_$DATE.sql.gz
# Garder seulement les 30 derniers jours
aws s3 ls s3://ophthocare-backups/postgresql/ | sort -r | tail -n +31 | awk '{print $4}' | xargs -I {} aws s3 rm s3://ophthocare-backups/postgresql/{}
```

