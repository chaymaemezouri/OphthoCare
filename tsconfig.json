{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./frontend/src/*"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "frontend/next-env.d.ts",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "frontend/.next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "frontend/node_modules", "frontend/.next", "Backend"]
}
